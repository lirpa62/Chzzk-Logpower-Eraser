{
  "manifest_version": 3,
  "name": "통나무 파워 지우개",
  "version": "1.0.0",
  "description": "치지직 통나무 파워 목록에서 원하지 않는 채널을 지워 깔끔하게 관리하세요.",
  "permissions": ["storage", "tabs", "scripting"],
  "host_permissions": [
    "https://game.naver.com/*",
    "https://api.chzzk.naver.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://game.naver.com/profile*"],
      "css": ["style.css"],
      "js": ["content.js"]
    }
  ],
  "icons": {
    "16": "icon_16.png",
    "48": "icon_48.png",
    "128": "icon_128.png"
  }
}
